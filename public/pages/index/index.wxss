/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  padding: 20px;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 10px;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  border: 2px solid #e94560;
  margin-right: 10px;
}

.nickname {
  font-size: 16px;
  color: white;
}

.tabs {
  display: flex;
  margin: 20px 0;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  padding: 5px;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 12px 0;
  color: rgba(255, 255, 255, 0.6);
  border-radius: 8px;
  transition: all 0.3s ease;
}

.tab.active {
  background: #e94560;
  color: white;
  font-weight: bold;
}

.room-list {
  height: calc(100vh - 250px);
}

.empty-tip {
  text-align: center;
  padding: 60px 20px;
  color: rgba(255, 255, 255, 0.4);
}

.room-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 15px;
  padding: 20px;
  margin-bottom: 15px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
}

.room-card:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.12);
}

.room-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.room-name {
  font-size: 18px;
  font-weight: bold;
  color: white;
}

.room-state {
  font-size: 12px;
  padding: 4px 12px;
  border-radius: 12px;
  background: #07c160;
  color: white;
}

.room-state.preflop,
.room-state.flop,
.room-state.turn,
.room-state.river,
.room-state.showdown {
  background: #e94560;
}

.room-players {
  color: rgba(255, 255, 255, 0.6);
  font-size: 14px;
}

/* 创建房间 */
.create-room {
  padding: 20px;
}

.input-group {
  margin-bottom: 25px;
}

.label {
  display: block;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 10px;
}

.input-field {
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 12px;
  padding: 15px;
  color: white;
  font-size: 16px;
}

.placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.btn-create {
  background: linear-gradient(135deg, #e94560 0%, #c73e54 100%);
  color: white;
  border: none;
  padding: 18px;
  border-radius: 25px;
  font-size: 18px;
  font-weight: bold;
  margin-top: 20px;
  box-shadow: 0 4px 15px rgba(233, 69, 96, 0.4);
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #1a1a2e;
  border-radius: 20px;
  padding: 30px;
  width: 80%;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  font-size: 20px;
  font-weight: bold;
  color: white;
  display: block;
  text-align: center;
  margin-bottom: 25px;
}

.btn-join {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: white;
  border: none;
  padding: 15px;
  border-radius: 25px;
  font-size: 16px;
  font-weight: bold;
  margin-top: 20px;
}