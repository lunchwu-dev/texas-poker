/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  padding: 30rpx;
  box-sizing: border-box;
}

/* 用户信息区 */
.user-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 0;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #e94560;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(233, 69, 96, 0.3);
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-name {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  margin-top: 20rpx;
}

.user-id {
  font-size: 26rpx;
  color: #aaa;
  margin-top: 10rpx;
}

/* 统计概览 */
.stats-overview {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.stats-card {
  flex: 1;
  background: linear-gradient(135deg, #e94560 0%, #c23a51 100%);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  margin: 0 10rpx;
  box-shadow: 0 8rpx 20rpx rgba(233, 69, 96, 0.3);
}

.stats-card:first-child {
  margin-left: 0;
}

.stats-card:last-child {
  margin-right: 0;
}

.stats-value {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

/* 详细统计 */
.stats-detail {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #e94560;
}

.stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stat-item:last-child {
  border-bottom: none;
}

.stat-item-label {
  font-size: 28rpx;
  color: #aaa;
}

.stat-item-value {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
}

/* 成就展示 */
.achievements {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.achievements-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.achievement-item {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  opacity: 0.5;
}

.achievement-item.unlocked {
  opacity: 1;
  background: rgba(233, 69, 96, 0.2);
  border: 2rpx solid #e94560;
}

.achievement-icon {
  font-size: 50rpx;
  margin-bottom: 10rpx;
}

.achievement-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.achievement-desc {
  font-size: 22rpx;
  color: #aaa;
}

/* 底部操作 */
.bottom-actions {
  margin-top: 40rpx;
}

.btn-logout {
  width: 100%;
  height: 90rpx;
  background: transparent;
  border: 2rpx solid #e94560;
  border-radius: 45rpx;
  color: #e94560;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-logout:active {
  background: rgba(233, 69, 96, 0.1);
}