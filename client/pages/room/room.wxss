/* pages/room/room.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  padding: 20px;
}

.room-header {
  display: flex;
  align-items: center;
  padding: 20px 0;
}

.back-btn {
  color: #e94560;
  font-size: 16px;
  padding: 10px;
}

.room-title {
  flex: 1;
  text-align: center;
  margin-right: 50px;
}

.room-name {
  display: block;
  font-size: 24px;
  font-weight: bold;
  color: white;
}

.room-id {
  display: block;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 5px;
}

.players-area {
  margin-top: 30px;
}

.players-title {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20px;
  text-align: center;
}

.players-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.player-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 15px;
  padding: 15px;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.player-card.empty {
  opacity: 0.5;
  border-style: dashed;
}

.player-avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  border: 2px solid #e94560;
  margin-bottom: 10px;
}

.empty-slot {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  border: 2px dashed rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10px;
  color: rgba(255, 255, 255, 0.3);
  font-size: 24px;
}

.player-name {
  font-size: 14px;
  color: white;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 80px;
}

.player-chips {
  display: flex;
  align-items: center;
  margin-top: 8px;
  font-size: 12px;
  color: #ffd700;
}

.chip-icon {
  margin-right: 5px;
}

.room-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20px;
  background: linear-gradient(180deg, transparent 0%, #1a1a2e 50%);
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.btn-invite {
  background: rgba(255, 255, 255, 0.1);
  color: white;
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 25px;
  padding: 15px;
  font-size: 16px;
}

.btn-start {
  background: linear-gradient(135deg, #e94560 0%, #c73e54 100%);
  color: white;
  border: none;
  border-radius: 25px;
  padding: 18px;
  font-size: 18px;
  font-weight: bold;
  box-shadow: 0 4px 15px rgba(233, 69, 96, 0.4);
}

.waiting-tip {
  text-align: center;
  color: rgba(255, 255, 255, 0.5);
  font-size: 14px;
  padding: 10px;
}